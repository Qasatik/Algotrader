# =====================================================================
#  Bybit Algo Trading Bot - Environment configuration
#  Copy this file to ".env" and fill in your real values.
#  NEVER commit the real ".env" file to version control.
# =====================================================================

# ---- Bybit API credentials -----------------------------------------
# Create API keys at https://www.bybit.com/app/user/api-management
# Use MAINNET keys only after thorough testnet validation.
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Use testnet first: https://testnet.bybit.com
BYBIT_TESTNET=true

# ---- Trading parameters --------------------------------------------
# Symbol to trade (linear perpetual on Bybit V5 unified account)
TRADING_SYMBOL=BTCUSDT

# Risk: fraction of equity risked per trade (e.g. 0.01 = 1%)
RISK_PER_TRADE=0.01

# Maximum simultaneous open positions
MAX_OPEN_POSITIONS=3

# Leverage (x). Set responsibly - higher = higher liquidation risk.
LEVERAGE=5

# ---- Risk circuit breakers (R1/R2) ---------------------------------
# Stop trading for the day if equity drops this fraction from day's open
MAX_DAILY_DRAWDOWN=0.03
# Pause for COOLDOWN_MINUTES after N losses in a row
MAX_CONSECUTIVE_LOSSES=5
COOLDOWN_MINUTES=60

# ---- Execution (E1) ------------------------------------------------
# Use maker (limit) orders to earn Bybit's negative fee rebate
USE_MAKER_ORDERS=true
# Seconds to wait for a maker fill before falling back to taker market
MAKER_REPRICE_TIMEOUT=2.0

# ---- ML / GPU -------------------------------------------------------
# Device for inference: "cuda", "cuda:0", or "cpu"
ML_DEVICE=cuda:0

# Model checkpoint path (PyTorch .pt/.pth)
ML_MODEL_PATH=models/price_predictor.pt

# Inference batch / sequence settings
ML_SEQUENCE_LEN=128
ML_CONFIDENCE_THRESHOLD=0.6

# ---- Data feed ------------------------------------------------------
# Orderbook depth to subscribe to (e.g. 1, 50, 200)
ORDERBOOK_DEPTH=50

# Kline (candle) interval: 1,3,5,15,30,60,240,D,W
KLINE_INTERVAL=1

# ---- Infrastructure -------------------------------------------------
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# HTTP REST timeout (seconds)
HTTP_TIMEOUT=10

# Prometheus metrics port
METRICS_PORT=9090

# ---- Telegram admin bot -------------------------------------------
# Get a token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated whitelist of numeric Telegram user IDs allowed to use the bot
TELEGRAM_ADMIN_IDS=123456789,987654321

# TOTP shared secret (base32). Generate with: python -m security.totp --generate
# Scan the QR code with Google Authenticator / Authy.
TOTP_SECRET=

# Seconds an authenticated Telegram session stays unlocked before re-prompting 2FA
SESSION_TTL=300
